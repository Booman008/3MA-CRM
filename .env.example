PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/three_ma_crm
JWT_SECRET=replace-with-a-long-random-secret
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Cloudflare R2 (file attachments). Leave blank to disable uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Google OAuth (Gmail import + Calendar task export). Leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override. If blank, the app infers this from the current host.
# Render inferred value: https://threema-crm.onrender.com/api/google/oauth/callback
# Local development value: http://localhost:3000/api/google/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=
