{
  "name": "3ma-crm",
  "version": "1.0.0",
  "description": "3MA CRM - Customer Relationship Management",
  "main": "server/index.js",
  "scripts": {
    "build": "node scripts/build-client.js",
    "crm:reset-data": "node scripts/reset-crm-entity-data.js",
    "legislators:import": "node scripts/import-legislators-from-csv.js --file \"3MA Mississippi Legislature Tracksheet - Scorecard_Public (1).csv\" --dry-run",
    "legislators:import:apply": "node scripts/import-legislators-from-csv.js --file \"3MA Mississippi Legislature Tracksheet - Scorecard_Public (1).csv\" --apply",
    "leads:reconcile": "node scripts/reconcile-leads-from-csv.js",
    "members:reconcile": "node scripts/reconcile-members-from-csv.js",
    "start": "node server/index.js",
    "dev": "node scripts/build-client.js && node server/index.js",
    "dev:client": "node scripts/build-client.js --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.3",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
